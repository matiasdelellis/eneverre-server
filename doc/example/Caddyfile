# Example Caddyfile for Eneverre.
#
# Eneverre is a single binary that records, relays and serves camera streams
# in-process when the [media] section is configured in eneverre.ini. Live and
# playback are served from the same REST API (same origin, same TLS cert, same
# auth), so the only thing this Caddyfile needs to do is reverse-proxy HTTPS
# to the Go binary. The embedded RTSP relay (default :8554, for Android/RTSP
# clients) does NOT go through Caddy — expose that port directly (firewalled)
# just like the API port.
#
# Topology:
#   - Caddy          : public entry point, ports 80/443 (TLS via Let's Encrypt)
#   - Eneverre (this): 127.0.0.1:8080  - serves the static UI at / and the
#                       REST API at /api/* (live + recordings included)
#   - RTSP relay     : 127.0.0.1:8554  - exposed directly, not proxied

nvr.example.com {
    encode gzip zstd

    reverse_proxy 127.0.0.1:8080

    header {
        # The UI and API share the same origin here, so no CORS is needed.
        # If you ever split them, uncomment and tighten the origin:
        # Access-Control-Allow-Origin https://nvr.example.com
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output file /var/log/caddy/eneverre.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}
